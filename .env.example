# Working with AI on *n branches -> name the compose project
COMPOSE_PROJECT_NAME=app-skeleton-dev

# This image prefix ensures the docker images don't collide with any other containers you have running locally.
# The prefix can be seen in both the docker-compose files eg: `container_name: ${IMAGE_PREFIX}nginx-dev`
IMAGE_PREFIX=skel-

# Local development uses NODE_ENV=local so the API serves the frontend dist
# folders from the mounted ./frontends volume (see FrontendAssetsService).
NODE_ENV=local

# mongodb+srv://<user>:<pass>@<sub.domain>.mongodb.net/?retryWrites=true&w=majority
MONGO_HOST=changeme.mongodb.net
MONGO_USER=changeme
MONGO_PW=changeme

# WorkOS Authentication (AuthKit)
WORKOS_CLIENT_ID=client_your_client_id
WORKOS_API_KEY=sk_your_api_key
WORKOS_REDIRECT_URI=https://localhost/api/auth/callback
SESSION_COOKIE_DOMAIN=localhost
WORKOS_LOGOUT_REDIRECT_URL=https://localhost
# SESSION_EXPIRY_DAYS=30

# Comma-separated emails granted the SUPER_ADMIN system role on first login
SUPER_ADMIN_EMAILS=

# Dev Authentication
# When enabled, every request is auto-authenticated as a dev user (no WorkOS needed)
# DEV_AUTO_SEED=false

# SMTP SERVER - Locally the emails are sent via mailhog: http://localhost:8025
# This sets up your compose file to send emails via mailhog
# Which overrides the dev/prod instances which default to use the sendgrid smtp server
EMAIL_PORT=1025
EMAIL_HOST=mailhog
EMAIL_SECURE=false
EMAIL_FALLBACK_FROM=noreply@example.com
EMAIL_SUPPORT=support@example.com
#EMAIL_USERNAME=sendgridusername
#EMAIL_PASSWORD=sendgridpassword
