# Server Configuration
PORT=8081

# Socket.IO Configuration
SOCKET_IO_PATH=/socket/socket-io
SOCKET_IO_CORS_ORIGIN=*

# MongoDB (shared database with api-mono for session validation)
MONGO_HOST=changeme.mongodb.net
MONGO_USER=changeme
MONGO_PW=changeme
# MONGO_DB=api-mono
# MONGO_PROTOCOL=mongodb+srv

# Dev auto-seed (bypass authentication in local development)
DEV_AUTO_SEED=true
DEV_USER_EMAIL=dev@temp-local-only.invalid
DEV_USER_NAME=Joe Dev User

# PubSub Configuration
# Each pod creates its own ephemeral subscription on the topic at boot, so
# there's no subscription name to configure here — only the shared topic.
# For local development, use the emulator.
PUBSUB_EMULATOR_HOST=localhost:8085
SOCKET_PUBSUB_PROJECT_ID=local-dev
SOCKET_PUBSUB_TOPIC=socket-events
SOCKET_PUBSUB_CREATE_TOPIC_IF_MISSING=true
# Subscription TTL when the pod stops pulling (defaults to 86400s = 1 day).
# SOCKET_PUBSUB_SUBSCRIPTION_EXPIRATION_SECONDS=86400

# For production, remove PUBSUB_EMULATOR_HOST and set:
# SOCKET_PUBSUB_PROJECT_ID=your-gcp-project-id
# SOCKET_PUBSUB_CREATE_TOPIC_IF_MISSING=false
