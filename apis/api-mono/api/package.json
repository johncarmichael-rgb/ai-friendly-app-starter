{
  "name": "api-mono",
  "description": "",
  "version": "0.0.1",
  "private": true,
  "author": "Cera",
  "scripts": {
    "build": "npm run clean && tsc && tsc-alias",
    "cli-script": "VERBOSE=true && node ./build/server.js -r ",
    "dev:build": "tsc-watch --preserveWatchOutput --onSuccess 'npx tsc-alias'",
    "dev:setup": "git config core.hooksPath githooks && cp -n .env.example .env",
    "dev:start": "tsc-watch --preserveWatchOutput --onSuccess 'sh -c \"npx tsc-alias && npm start\"'",
    "dev:debug": "tsc-watch --preserveWatchOutput --onSuccess 'sh -c \"npx tsc-alias && node --inspect=127.0.0.1:9229 ./build/server.js\"'",
    "jest": "node --random-seed=42 node_modules/.bin/jest",
    "lint": "eslint 'src/**/*.{js,ts,tsx}'",
    "lint:fix": "npm run lint -- --fix",
    "start": "node ./build/server.js",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "ENVIRONMENT=test npm run jest -- --silent --runInBand",
    "test:unit:single": "npm run jest -- --clearCache && ENVIRONMENT=test npm run jest -- --collectCoverage false --verbose --forceExit --detectOpenHandles",
    "clean": "rm -rf build",
    "prettier": "prettier --check 'src/**/*.{js,ts,tsx,json}'",
    "prettier:fix": "prettier --write 'src/**/*.{js,ts,tsx,json}'",
    "generate:server": "generate-it ../api-spec/release/api-spec.yml --yes -t https://github.com/johncarmichael-rgb/gen-tpl-express-server.git",
    "migrate-mongo": "migrate-mongo",
    "migration:create": "migrate-mongo create",
    "migration:up": "migrate-mongo up",
    "migration:down": "migrate-mongo down",
    "migration:status": "migrate-mongo status"
  },
  "dependencies": {
    "celebrate": "^15.0.3",
    "cli-color": "^2.0.4",
    "command-line-args": "^5.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-form-data": "^3.0.1",
    "fs-extra": "^11.3.5",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.1",
    "morgan": "^1.11.0",
    "object-reduce-by-map": "^3.3.0",
    "proc-env-helper": "^1.1.0",
    "recursive-readdir-sync": "^1.0.6",
    "request-ip": "^3.3.0",
    "tslib": "^2.8.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "@google-cloud/pubsub": "^5.3.1",
    "@google-cloud/storage": "^7.21.0",
    "@typegoose/typegoose": "~13.3.0",
    "cookie": "^1.1.1",
    "load-mongoose": "^4.0.0",
    "migrate-mongo": "^11.0.0",
    "mongoose": "~9.6.1",
    "nunjucks-emailer": "^5.0.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/cli-color": "^2.0.6",
    "@types/command-line-args": "^5.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-form-data": "^2.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/request-ip": "^0.0.41",
    "@types/validator": "^13.15.10",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-deprecate": "^0.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "tsc-watch": "^6.2.0",
    "typescript": "^5.8.3",
    "@types/cookie": "^1.0.0",
    "@types/migrate-mongo": "^10.0.6",
    "@types/mime-types": "^3.0.1",
    "generate-it": "^5.63.0"
  },
  "mockingServer": false,
  "overrides": {
    "google-auth-library": "10.5.0"
  }
}
