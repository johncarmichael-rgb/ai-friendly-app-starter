# Full settings available here: src/config.ts

# PORT default is 8080
# PORT=8000

# Dev Authentication
# When enabled, every request is auto-authenticated as a dev user (no WorkOS needed)
# DEV_AUTO_SEED=false

# WorkOS Authentication (AuthKit)
WORKOS_CLIENT_ID=client_your_client_id
WORKOS_API_KEY=sk_your_api_key
WORKOS_REDIRECT_URI=https://localhost/api/auth/callback
# SESSION_COOKIE_DOMAIN=localhost
# SESSION_EXPIRY_DAYS=30
# WORKOS_LOGOUT_REDIRECT_URL=https://localhost

# Comma-separated emails granted the SUPER_ADMIN system role on first login
SUPER_ADMIN_EMAILS=

# mongodb+srv://<user>:<pass>@<sub.domain>.mongodb.net/?retryWrites=true&w=majority
MONGO_HOST=changeme.mongodb.net
MONGO_USER=changeme
MONGO_PW=changeme

# Google Cloud Storage - Frontend Assets (production serving; locally the
# mounted frontends/<app>/dist folders are used when NODE_ENV=local)
GCS_FRONTEND_BUCKET=app-skeleton-frontends-dev

# SMTP - locally emails are captured by mailhog (http://localhost:8025)
# EMAIL_HOST=mailhog
# EMAIL_PORT=1025
# EMAIL_SECURE=false
# EMAIL_FALLBACK_FROM=noreply@example.com
# EMAIL_SUPPORT=support@example.com

# Socket PubSub (defaults on when GCP_PROJECT_ID or PUBSUB_EMULATOR_HOST is set)
# SOCKET_PUBSUB_TOPIC=socket-events
# SOCKET_PUBSUB_CREATE_TOPIC_IF_MISSING=true
